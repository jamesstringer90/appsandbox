<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.appsandbox.agent</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Library/AppSandbox/appsandbox-agent</string>
    </array>
    <key>MachServices</key>
    <dict>
        <key>com.appsandbox.agent.clipboard</key>
        <true/>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/var/log/appsandbox-agent.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/appsandbox-agent.log</string>
    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
